{
  "name": "ktl-calculator-mcp",
  "version": "1.0.0",
  "description": "KTL 정도검사 계산기 MCP 서버 (수수료 조회 · 오차율 계산)",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "ktl-calculator-mcp": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "vite",
    "gen:claydox": "node src/genClaydoxJson.js",
    "gen:index": "node src/buildIndex.js",
    "prebuild": "node src/genClaydoxJson.js && node src/buildIndex.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test/smoke.test.js && node test/precision.test.js",
    "check:laws": "node src/checkLaws.js",
    "sync-excel": "python3 scripts/sync-excel.py",
    "sync-build": "npm run sync-excel && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/blob": "^2.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vite": "^5.4.11"
  }
}
